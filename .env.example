# App (build-time) env — copy to .env for local dev and set in the Vercel project.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"

# The variables below are NOT app env vars. Luna / moderation run in Supabase
# Edge Functions; set these as Supabase secrets (supabase secrets set …), not here:
#   AI_GATEWAY_URL       e.g. https://openrouter.ai/api/v1
#   AI_GATEWAY_API_KEY   your AI provider key
#   AI_AUDIO_URL         e.g. https://api.openai.com/v1   (TTS/STT; optional)
#   AI_AUDIO_API_KEY     audio provider key               (optional)
